# Application
APP_NAME=TextLens
APP_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=true
ALLOWED_HOSTS=*

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/textlens
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CELERY_URL=redis://localhost:6379/1

# AWS S3 / Cloudflare R2
S3_BUCKET_NAME=your-bucket-name
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com  # For R2
USE_R2=false  # Set to true to use Cloudflare R2 instead of AWS S3

# Google Cloud Vision API
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/google-credentials.json
GOOGLE_CLOUD_PROJECT=your-project-id

# OCR.space API (free OCR service)
OCR_SPACE_API_KEY=your-ocr-space-api-key
OCR_PROVIDER=ocr_space  # "ocr_space" or "google_vision"

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=dall-e-3

# Stability AI
STABILITY_API_KEY=sk-your-stability-ai-api-key
STABILITY_ENGINE_ID=stable-diffusion-xl-1024-v1-0

# Image Generation Provider (openai or stability)
IMAGE_GENERATION_PROVIDER=stability

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Apple OAuth
APPLE_CLIENT_ID=com.yourcompany.textlens
APPLE_TEAM_ID=your-team-id
APPLE_KEY_ID=your-key-id
APPLE_PRIVATE_KEY_PATH=/app/secrets/apple-private-key.p8

# Credits Config
FREE_DAILY_QUOTA=3
LOW_QUALITY_COST=5
MID_QUALITY_COST=15
HIGH_QUALITY_COST=25
DAILY_CHECKIN_REWARD=2
AD_REWARD_CREDITS=3
AD_DAILY_LIMIT=5
INVITE_REWARD=20
REGISTER_REWARD=10

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=300
